{
  "name": "Code Editor",
  "short_name": "CodeEdit",
  "description": "A powerful code editor with multi-file support, syntax highlighting, and more",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#3b82f6",
  "orientation": "any",
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "categories": ["developer tools", "productivity"],
  "shortcuts": [
    {
      "name": "New File",
      "short_name": "New",
      "description": "Create a new file",
      "url": "/?action=new",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "text/javascript": [".js", ".mjs", ".cjs"],
        "text/typescript": [".ts", ".tsx"],
        "text/python": [".py"],
        "text/html": [".html", ".htm"],
        "text/css": [".css"],
        "application/json": [".json"],
        "text/markdown": [".md", ".markdown"],
        "text/xml": [".xml", ".svg"],
        "text/yaml": [".yaml", ".yml"],
        "text/plain": [".txt"]
      }
    }
  ]
}
